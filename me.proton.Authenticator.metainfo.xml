<component type="desktop-application">
  <id>me.proton.Authenticator</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <name>Proton Authenticator</name>
  <summary>Two-factor authentication app by Proton</summary>

  <description>
    <p>
      Proton Authenticator is a two-factor authentication (2FA) app that works
      with any service supporting the TOTP or HOTP standards. It integrates with
      your Proton Account to back up and sync your 2FA tokens end-to-end encrypted
      across all your devices.
    </p>
    <p>Features:</p>
    <ul>
      <li>Compatible with any service that supports TOTP or HOTP</li>
      <li>End-to-end encrypted backup and sync via Proton Account</li>
      <li>Import tokens from other authenticator apps</li>
      <li>Offline support — codes generated entirely on-device</li>
    </ul>
  </description>

  <url type="homepage">https://proton.me/authenticator</url>
  <url type="help">https://proton.me/support/authenticator-app</url>
  <url type="bugtracker">https://github.com/ProtonMail/WebClients/issues</url>

  <launchable type="desktop-id">me.proton.Authenticator.desktop</launchable>

  <categories>
    <category>Utility</category>
    <category>Security</category>
  </categories>

  <keywords>
    <keyword>2FA</keyword>
    <keyword>TOTP</keyword>
    <keyword>authenticator</keyword>
    <keyword>proton</keyword>
    <keyword>otp</keyword>
  </keywords>

  <provides>
    <binary>proton-authenticator</binary>
  </provides>

